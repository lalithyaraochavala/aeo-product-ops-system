# Anthropic API key — used by all 5 agents
ANTHROPIC_API_KEY=

# Google PageSpeed Insights API key — used by the Technical SEO agent for Core Web Vitals
PAGESPEED_API_KEY=

# Database — defaults to a local SQLite file if left blank
DATABASE_URL=

# Comma-separated list of frontend origins allowed to call this API (CORS).
# Defaults to http://localhost:3000 if left blank. For production, add your
# deployed frontend URL, e.g.:
# FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app
FRONTEND_ORIGINS=
